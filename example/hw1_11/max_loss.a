// HW1 Q11(i): maximum loss per stock (buy then sell later)
// Schema: ticks(ID, date, endofdayprice)
// worst_loss = min_j (price[j] - max_{i<j} price[i]) after ASSUMING ASC ID, ASC date

CREATE TABLE ticks(ID STRING, date INT, endofdayprice FLOAT)

LOAD DATA INFILE "example_ticks.csv" INTO TABLE ticks FIELDS TERMINATED BY ","

SELECT ID,
       min(endofdayprice - maxs(prev(endofdayprice))) AS worst_loss
FROM ticks
ASSUMING ASC ID, ASC date
GROUP BY ID
